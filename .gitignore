# =============================================================================
# CMake / C build artifacts
# =============================================================================

# Out-of-source build directories (any name starting with build)
build*/

# Release staging
dist/

# CMake generated files (in case of in-source build accidents)
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
CTestTestfile.cmake
Testing/

# Compiled objects
*.o
*.obj
*.a
*.lib
*.so
*.so.*
*.dylib
*.dll
*.exe

# Debug symbols
*.dSYM/
*.pdb

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
*~
.cache/
compile_commands.json

# Diagnostic
diagnostic/